# ─────────────────────────────────────────────────────────────────────────────
# ADB-RAG-1 환경 변수 예시 파일
# 이 파일을 복사하여 .env 파일을 만들고, 실제 값을 채워 넣으세요.
#   cp .env.example .env
#
# ⚠️  .env 파일은 절대 Git에 커밋하지 마세요. (.gitignore에 포함되어 있습니다)
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────
# Databricks 접속 정보
# ─────────────────────────────────────────
# Workspace URL (예: https://adb-1234567890123456.7.azuredatabricks.net)
DATABRICKS_HOST=https://<workspace-id>.azuredatabricks.net

# Personal Access Token
# 발급 경로: User Settings → Developer → Access Tokens → Generate New Token
DATABRICKS_TOKEN=dapi...

# 클러스터 ID (선택 사항 - 노트북 실행 시 필요)
# 클러스터 페이지 URL에서 확인: /clusters/<cluster-id>
DATABRICKS_CLUSTER_ID=<cluster-id>

# ─────────────────────────────────────────
# Unity Catalog
# ─────────────────────────────────────────
# 사용할 Catalog 이름
DATABRICKS_CATALOG=rag_catalog

# 사용할 Schema(Database) 이름
DATABRICKS_SCHEMA=sop_rag

# ─────────────────────────────────────────
# Volume (PDF 원본 문서 저장 경로)
# ─────────────────────────────────────────
# Unity Catalog Volume DBFS 경로
# 형식: /Volumes/<catalog>/<schema>/<volume_name>
DATABRICKS_VOLUME_PATH=/Volumes/rag_catalog/sop_rag/pdf_volume

# ─────────────────────────────────────────
# Foundation Model API 엔드포인트
# ─────────────────────────────────────────
# 임베딩 모델 엔드포인트 이름
# 옵션: databricks-gte-large-en / databricks-bge-large-en
# 한글 문서의 경우 소량 샘플 테스트 후 모델 결정 권장
DATABRICKS_EMBEDDING_ENDPOINT=databricks-gte-large-en

# 생성(LLM) 모델 엔드포인트 이름
# 옵션: databricks-meta-llama-3-1-70b-instruct / databricks-dbrx-instruct
DATABRICKS_LLM_ENDPOINT=databricks-meta-llama-3-1-70b-instruct

# ─────────────────────────────────────────
# Vector Search
# ─────────────────────────────────────────
# Managed Vector Search Endpoint 이름
DATABRICKS_VECTOR_SEARCH_ENDPOINT=rag-vector-search

# Vector Index 전체 경로 (catalog.schema.index_name 형식)
DATABRICKS_VECTOR_INDEX_NAME=rag_catalog.sop_rag.chunk_index

# ─────────────────────────────────────────
# Delta Table
# ─────────────────────────────────────────
# 청크 데이터가 저장될 Delta Table 전체 경로 (catalog.schema.table_name 형식)
DATABRICKS_CHUNKS_TABLE=rag_catalog.sop_rag.chunks
